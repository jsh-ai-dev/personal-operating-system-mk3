# AWS data-box 전용 예시 환경파일 (실사용은 .env.data-box 로 복사)
# cp .env.data-box.example .env.data-box

MK3_MONGO_USERNAME=pos
MK3_MONGO_PASSWORD=REPLACE_STRONG_MONGO_PASSWORD
MK3_MONGO_DB=pos_mk3
MK3_MONGO_BIND=0.0.0.0
MK3_MONGO_PORT=27017
MK3_TZ=Asia/Seoul

MK3_QDRANT_API_KEY=REPLACE_STRONG_QDRANT_API_KEY
MK3_QDRANT_BIND=0.0.0.0
MK3_QDRANT_HTTP_PORT=6333
MK3_QDRANT_GRPC_PORT=6334
